#!/usr/bin/env ruby
# frozen_string_literal: true

require 'yaml'
require 'pathname'
require 'fileutils'
require 'json'

SSOT_ROOT = Pathname.new(__dir__).expand_path
BUILD_DIR = SSOT_ROOT.join('build')
INDEX_PATH = SSOT_ROOT.join('index.yaml')
INDEX_JSON_PATH = SSOT_ROOT.join('index.json')
REGISTRY_PATH = SSOT_ROOT.join('registry/platforms.yaml')

# ─── Helpers ────────────────────────────────────────────────────────────────────

def validate_install_path(path_str, base_path, context:)
  # Expand path
  path = Pathname.new(path_str)
  path = path.expand_path unless path.absolute?
  absolute = base_path.join(path)
  
  # Resolve symlinks and normalize
  begin
    real = absolute.realpath
  rescue Errno::ENOENT
    # If path doesn't exist yet, normalize without realpath
    real = absolute.expand_path
  end

  # Ensure it's within base_path (prevent traversal)
  base_real = base_path.realpath rescue base_path.expand_path
  unless real.to_s.start_with?(base_real.to_s + File::SEPARATOR) || real == base_real
    raise "Security: install path outside base directory (#{context}): #{real} not under #{base_real}"
  end

  real
end

def validate_install_path(path_str, base_path, context:)
  # Expand path
  path = Pathname.new(path_str)
  path = path.expand_path unless path.absolute?
  absolute = base_path.join(path)
  
  # Resolve symlinks and normalize
  begin
    real = absolute.realpath
  rescue Errno::ENOENT
    # If path doesn't exist yet, normalize without realpath
    real = absolute.expand_path
  end

  # Ensure it's within base_path (prevent traversal)
  base_real = base_path.realpath rescue base_path.expand_path
  unless real.to_s.start_with?(base_real.to_s + File::SEPARATOR) || real == base_real
    raise "Security: install path outside base directory (#{context}): #{real} not under #{base_real}"
  end

  real
end

# ─── Load data ─────────────────────────────────────────────────────────────────

unless INDEX_PATH.exist?
  abort "❌ Index not found: #{INDEX_PATH}. Run `ruby ssot/build.rb` first."
end

index = YAML.safe_load(INDEX_PATH.read, permitted_classes: [Symbol])
platforms = YAML.safe_load(REGISTRY_PATH.read, permitted_classes: [Symbol])

# ─── Determine target platform ─────────────────────────────────────────────────

dry_run = false
target_platform = ARGV[0]

# Parse flags
args = ARGV.reject { |a| a.start_with?('-') }
target_platform = args[0] if args[0]

flags = ARGV.select { |a| a.start_with?('--') }
dry_run = true if flags.include?('--dry-run')

unless target_platform
  abort "Usage: ruby ssot/install.rb <platform> [--dry-run]\n\nAvailable platforms: #{platforms.keys.join(', ')}"
end

platform_cfg = platforms[target_platform]
unless platform_cfg
  abort "❌ Unknown platform: #{target_platform}"
end

puts "🎯 Installing to: #{platform_cfg['display_name']} (#{target_platform})"
puts ""

# ─── Resolve platform paths ────────────────────────────────────────────────────

base_path = Pathname.new(platform_cfg['base_path'])
base_path = base_path.expand_path

# Create base directory if missing
base_path.mkpath unless base_path.exist?

rules_dir = base_path.join(platform_cfg['rules_dir'] || 'rules')
skills_dir = base_path.join(platform_cfg['skills_dir'] || 'skills')
docs_dir = base_path.join(platform_cfg['docs_dir'] || 'docs')

# Create directories
[rules_dir, skills_dir, docs_dir].each { |d| d.mkpath unless d.exist? }

config_file = base_path.join(platform_cfg['config_file']) if platform_cfg['config_file']

# ─── Collect packages to install ───────────────────────────────────────────────

# All packages that have a build artifact for this platform
packages_to_install = []

index['packages'].each do |pkgname, pkgdata|
  pkgdata['installed'] ||= []
  # Check if built for this platform
  built_checksum = pkgdata['checksums'] && pkgdata['checksums']['built'] && pkgdata['checksums']['built'][target_platform]
  next unless built_checksum

  # Find the PKGBUILD to get target config
  pkgbuild_path = SSOT_ROOT.join('packages', pkgname, 'PKGBUILD')
  next unless pkgbuild_path.exist?

  pkgbuild = YAML.safe_load(pkgbuild_path.read, permitted_classes: [Symbol])
  targets = pkgbuild['targets']
  targets = [targets] unless targets.is_a?(Array)

  targets.each do |tgt|
    next unless tgt['platform'] == target_platform
    next unless tgt['output']  # skip if no output

    packages_to_install << {
      pkgname: pkgname,
      pkgbuild: pkgbuild,
      target: tgt,
      built_checksum: built_checksum,
      already_installed: pkgdata['installed'].any? { |i| i['platform'] == target_platform && i['checksum'] == built_checksum }
    }
  end
end

if packages_to_install.empty?
  puts "📦 No packages built for #{target_platform}. Run `ruby ssot/build.rb` first."
  exit 0
end

puts "📦 #{packages_to_install.size} package(s) to install\n"

# ─── Install each package ──────────────────────────────────────────────────────

installed_this_run = []
skipped_this_run = []

packages_to_install.each do |entry|
  pkgname = entry[:pkgname]
  tgt = entry[:target]
  output = tgt['output']
  format_type = tgt['format']
  build_file = BUILD_DIR.join(target_platform, output)

  unless build_file.exist?
    warn "  ⚠ Build artifact missing: #{build_file} (skipping)"
    skipped_this_run << pkgname
    next
  end

  content = build_file.read
  installed = false

  case format_type
  when 'directory'
    # Rule files go to rules_dir, skill files to skills_dir
    # Determine by pkgbuild source? Or by filename extension? Use output path heuristic
    if output.end_with?('.md')
      # Assume rule if placed in rules_dir target
      target_path = rules_dir.join(output)
    else
      target_path = skills_dir.join(output)
    end

    if dry_run
      puts "  [DRY-RUN] Would symlink: #{build_file} → #{target_path}"
      installed = true
    else
      # Symlink for directory agents
      begin
        # Remove existing symlink/file if present
        FileUtils.rm_f(target_path) if target_path.exist? || target_path.symlink?
        FileUtils.ln_s(build_file, target_path)
        puts "  ✓ Symlinked: #{output} → #{target_path}"
        installed = true
      rescue => e
        warn "  ✗ Symlink failed for #{output}: #{e.message}"
      end
    end

  when 'import'
    # Inject @import directive into platform config
    unless config_file && config_file.exist?
      warn "  ⚠ Config file not found: #{config_file} (skipping #{pkgname})"
      next
    end

    import_line = "@import '#{build_file.expand_path}'"
    config_content = config_file.read

    unless config_content.include?(import_line)
      if dry_run
        puts "  [DRY-RUN] Would inject @import into #{config_file}"
        installed = true
      else
        # Prepend import to top of config
        new_content = "#{import_line}\n#{config_content}"
        config_file.write(new_content)
        puts "  ✓ Injected @import into #{config_file}"
        installed = true
      end
    else
      puts "  ✓ Already injected (#{pkgname})"
      installed = true
    end

   when 'skill'
     install_cfg = tgt['install'] || {}
     install_type = install_cfg['type'] || platform_cfg['skill_install']&.dig('type') || 'copy'
     target_dir_cfg = install_cfg['target_dir'] || platform_cfg['skill_install']&.dig('target_dir')
     target_file_cfg = install_cfg['target_file'] || platform_cfg['skill_install']&.dig('target_file')

     case install_type
     when 'copy'
       # Resolve and validate target directory
       target_dir = if target_dir_cfg
                      validate_install_path(target_dir_cfg, base_path, context: "#{pkgname} target_dir")
                    else
                      skills_dir
                    end
       target_path = target_dir.join(output)

       if dry_run
         puts "  [DRY-RUN] Would copy skill: #{build_file} → #{target_path}"
         installed = true
       else
         FileUtils.rm_f(target_path) if target_path.exist? || target_path.symlink?
         FileUtils.cp(build_file, target_path)
         puts "  ✓ Copied skill: #{output} → #{target_path}"
         installed = true
       end

     when 'append'
       unless target_file_cfg
         warn "  ⚠ No target_file specified for append (#{pkgname})"
         next
       end
       target_file = validate_install_path(target_file_cfg, base_path, context: "#{pkgname} target_file")
       
       unless target_file.exist?
         warn "  ⚠ Target skill file not found: #{target_file} (skipping)"
         next
       end
       if dry_run
         puts "  [DRY-RUN] Would append skill to #{target_file}"
         installed = true
       else
         File.write(target_file, "\n\n--- #{pkgname} ---\n", mode: 'a')
         File.write(target_file, content, mode: 'a')
         puts "  ✓ Appended skill to #{target_file}"
         installed = true
       end

     else
       warn "  ⚠ Unknown skill install type: #{install_type}"
     end
     
     # Resolve target file for append operations
     target_file_cfg = install_cfg['target_file'] || platform_cfg['skill_install']&.dig('target_file')

     case install_type
     when 'copy'
       target_path = target_dir.join(output)

       if dry_run
         puts "  [DRY-RUN] Would copy skill: #{build_file} → #{target_path}"
         installed = true
       else
         FileUtils.rm_f(target_path) if target_path.exist? || target_path.symlink?
         FileUtils.cp(build_file, target_path)
         puts "  ✓ Copied skill: #{output} → #{target_path}"
         installed = true
       end

     when 'append'
       unless target_file_cfg
         warn "  ⚠ No target_file specified for append (#{pkgname})"
         next
       end
       target_file = validate_install_path(target_file_cfg, base_path, context: "#{pkgname} target_file")
       
       unless target_file.exist?
         warn "  ⚠ Target skill file not found: #{target_file} (skipping)"
         next
       end
       if dry_run
         puts "  [DRY-RUN] Would append skill to #{target_file}"
         installed = true
       else
         File.write(target_file, "\n\n--- #{pkgname} ---\n", mode: 'a')
         File.write(target_file, content, mode: 'a')
         puts "  ✓ Appended skill to #{target_file}"
         installed = true
       end

     else
       warn "  ⚠ Unknown skill install type: #{install_type}"
     end
     
     # Resolve target file (for append)
     target_file_cfg = install_cfg['target_file'] || platform_cfg['skill_install']&.dig('target_file')

     if install_type == 'copy'
       target_path = target_dir.join(output)

       if dry_run
         puts "  [DRY-RUN] Would copy skill: #{build_file} → #{target_path}"
         installed = true
       else
         FileUtils.rm_f(target_path) if target_path.exist? || target_path.symlink?
         FileUtils.cp(build_file, target_path)
         puts "  ✓ Copied skill: #{output} → #{target_path}"
         installed = true
       end

     elsif install_type == 'append'
       unless target_file_cfg
         warn "  ⚠ No target_file specified for append (#{pkgname})"
         next
       end
       target_file = validate_install_path(target_file_cfg, base_path, context: "#{pkgname} target_file")
       
       unless target_file.exist?
         warn "  ⚠ Target skill file not found: #{target_file} (skipping)"
         next
       end
       if dry_run
         puts "  [DRY-RUN] Would append skill to #{target_file}"
         installed = true
       else
         File.write(target_file, "\n\n--- #{pkgname} ---\n", mode: 'a')
         File.write(target_file, content, mode: 'a')
         puts "  ✓ Appended skill to #{target_file}"
         installed = true
       end

     else
       warn "  ⚠ Unknown skill install type: #{install_type}"
     end  # end if install_type

     elsif install_type == 'append'
       unless target_file_cfg
         warn "  ⚠ No target_file specified for append (#{pkgname})"
         next
       end
       target_file = validate_install_path(target_file_cfg, base_path, context: "#{pkgname} target_file")
       
       unless target_file.exist?
         warn "  ⚠ Target skill file not found: #{target_file} (skipping)"
         next
       end
       if dry_run
         puts "  [DRY-RUN] Would append skill to #{target_file}"
         installed = true
       else
         File.write(target_file, "\n\n--- #{pkgname} ---\n", mode: 'a')
         File.write(target_file, content, mode: 'a')
         puts "  ✓ Appended skill to #{target_file}"
         installed = true
       end

     else
       warn "  ⚠ Unknown skill install type: #{install_type}"
     end

      if dry_run
        puts "  [DRY-RUN] Would copy skill: #{build_file} → #{target_path}"
        installed = true
      else
        # Remove existing symlink/file if present
        FileUtils.rm_f(target_path) if target_path.exist? || target_path.symlink?
        FileUtils.cp(build_file, target_path)
        puts "  ✓ Copied skill: #{output} → #{target_path}"
        installed = true
      end

    when 'append'
      target_file = Pathname.new(install_cfg['target_file'] || platform_cfg['skill_install']&.dig('target_file'))
      unless target_file
        warn "  ⚠ No target_file specified for append install (#{pkgname})"
        next
      end
      target_file = base_path.join(target_file) unless target_file.absolute?
      unless target_file.exist?
        warn "  ⚠ Target skill file not found: #{target_file} (skipping)"
        next
      end
      if dry_run
        puts "  [DRY-RUN] Would append skill to #{target_file}"
        installed = true
      else
        # Append with separator
        File.write(target_file, "\n\n--- #{pkgname} ---\n", mode: 'a')
        File.write(target_file, content, mode: 'a')
        puts "  ✓ Appended skill to #{target_file}"
        installed = true
      end

    else
      warn "  ⚠ Unknown skill install type: #{install_type}"
    end

    else
      warn "  ⚠ Unknown format: #{format_type}"
    end

  # Record installation status
  if installed
    installed_entry = {
      'platform' => target_platform,
      'version' => entry[:pkgbuild]['pkgver'],
      'output' => output,
      'checksum' => entry[:built_checksum],
      'installed_at' => Time.now.utc.strftime('%Y-%m-%dT%H:%M:%SZ')
    }

    pkgdata = index['packages'][pkgname]
    pkgdata['installed'].reject! { |i| i['platform'] == target_platform && i['output'] == output }
    pkgdata['installed'] << installed_entry

    installed_this_run << pkgname
  else
    skipped_this_run << pkgname
  end
end

# ─── Write updated index ───────────────────────────────────────────────────────

unless dry_run
  index['generated'] = Time.now.utc.strftime('%Y-%m-%dT%H:%M:%SZ')
  INDEX_PATH.write(index.to_yaml)
  INDEX_JSON_PATH.write(JSON.pretty_generate(index))
  
  puts ""
  puts "📝 Index updated."
  puts "✅ Installed: #{installed_this_run.size} package(s)"
  puts "⏭  Skipped: #{skipped_this_run.size} package(s)"
else
  puts ""
  puts "💡 Dry-run: no changes written to index or filesystem."
  puts "   Would install: #{installed_this_run.size} package(s)"
  puts "   Would skip: #{skipped_this_run.size} package(s)"
end

puts ""
puts "🎉 Installation complete for #{target_platform}!"
